{
  "name": "flowme",
  "version": "1.0.15.4",
  "description": "Home Assistant custom Lovelace card: animated flow visualisation over a user-supplied background image.",
  "type": "module",
  "main": "dist/flowme-card.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "type-check:tests": "tsc -p tsconfig.test.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run type-check && npm run type-check:tests && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "custom-card-helpers": "1.9.0",
    "lit": "3.2.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.15.0",
    "@typescript-eslint/parser": "8.15.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "9.15.0",
    "happy-dom": "^20.9.0",
    "typescript": "5.6.3",
    "typescript-eslint": "8.15.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fxgamer-debug/flowme.git"
  },
  "license": "MIT",
  "keywords": [
    "home-assistant",
    "lovelace",
    "hacs",
    "custom-card",
    "flow",
    "animation"
  ]
}
