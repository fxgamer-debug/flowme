{
  "name": "flowme",
  "version": "2.5.8",
  "description": "Animated flow visualisation with freely positioned nodes for Home Assistant",
  "type": "module",
  "main": "dist/flowme-card.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "type-check:tests": "tsc -p tsconfig.test.json",
    "lint": "eslint src tests --max-warnings 0",
    "lint:fix": "eslint src tests --fix --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run type-check && npm run type-check:tests && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "custom-card-helpers": "^2.0.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fxgamer-debug/flowme.git"
  },
  "license": "MIT",
  "keywords": [
    "home-assistant",
    "lovelace",
    "hacs",
    "custom-card",
    "flow",
    "animation"
  ]
}
